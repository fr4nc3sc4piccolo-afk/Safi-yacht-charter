:root {
  /* Colori primari */
  --terracotta: #C47E72;
  --sand: #C29C7C;
  --warm-gray: #D2CBC4;
  --sage: #BDC6B6;
  --black: #000000;
  --white: #FFFFFF;
  
  /* Tipografia */
  --font-display: 'Sheina', serif;
  --font-body: 'Hiragino Kaku Gothic Pro', sans-serif;
  
  /* Spacing */
  --space-xs: 0.5rem;
  --space-sm: 1rem;
  --space-md: 2rem;
  --space-lg: 4rem;
  --space-xl: 8rem;
}
